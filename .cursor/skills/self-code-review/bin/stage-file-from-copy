#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: stage-file-from-copy <repo-relative-path> <copy-file>" >&2
}

if [[ $# -ne 2 ]]; then
  usage
  exit 2
fi

path=$1
copy=$2

if [[ $path = /* ]]; then
  echo "stage-file-from-copy: path must be repo-relative: $path" >&2
  exit 2
fi

if [[ ! -f $copy ]]; then
  echo "stage-file-from-copy: copy file does not exist: $copy" >&2
  exit 2
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

git ls-files --error-unmatch -- "$path" >/dev/null

mode=$(git ls-files -s -- "$path" | awk '{ print $1; exit }')
blob=$(git hash-object -w -- "$copy")

git update-index --cacheinfo "$mode,$blob,$path"

git diff --cached --stat -- "$path"
git diff --cached -- "$path"

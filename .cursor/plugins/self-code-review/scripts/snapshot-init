#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

branch=$(git rev-parse --abbrev-ref HEAD)
snapshot="review-snapshot-$branch"

if git show-ref --verify --quiet "refs/heads/$snapshot"; then
    echo "RESUMED $snapshot"
    exit 0
fi

if [ -z "$(git status --porcelain --untracked-files=all)" ]; then
    echo "CLEAN" >&2
    exit 1
fi

git checkout -b "$snapshot" --quiet
git add -A
git commit --quiet -m "REVIEW SNAPSHOT"
git checkout --quiet "$branch"

echo "NEW $snapshot"

#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 1 ]; then
    echo "usage: apply-batch <patch-file>" >&2
    exit 2
fi

patch=$1

if [ ! -f "$patch" ]; then
    echo "MISSING_PATCH $patch" >&2
    exit 2
fi

cd "$(git rev-parse --show-toplevel)"

branch=$(git rev-parse --abbrev-ref HEAD)
snapshot="review-snapshot-$branch"

if ! git show-ref --verify --quiet "refs/heads/$snapshot"; then
    echo "MISSING $snapshot" >&2
    exit 1
fi

pending=$(git diff --name-only HEAD "$snapshot" | sort -u)
patched=$(git apply --numstat "$patch" 2>/dev/null | awk '{print $3}' | sort -u)

unexpected=$(comm -23 <(echo "$patched") <(echo "$pending") | sed '/^$/d')
if [ -n "$unexpected" ]; then
    {
        echo "OUT_OF_SCOPE"
        echo "$unexpected"
    } >&2
    exit 1
fi

if ! git apply --check "$patch" 2>/tmp/apply-batch-check.log; then
    {
        echo "REJECTED"
        cat /tmp/apply-batch-check.log
    } >&2
    rm -f /tmp/apply-batch-check.log
    exit 1
fi
rm -f /tmp/apply-batch-check.log

git apply "$patch"

echo "APPLIED"
echo "$patched"
